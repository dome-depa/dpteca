# VirtualHost per il sottodominio dpteca.casanausicaa.it
# Copia questo file in /etc/apache2/sites-available/dpteca.casanausicaa.it.conf
# e modifica i percorsi se il progetto non è in /home/dpteca/dpteca

<VirtualHost *:80>
    ServerName dpteca.casanausicaa.it

    # Directory del progetto
    DocumentRoot /home/dpteca/dpteca

    # Directory per file statici
    Alias /static /home/dpteca/dpteca/staticfiles
    <Directory /home/dpteca/dpteca/staticfiles>
        Require all granted
    </Directory>

    # Directory per file media
    Alias /media /home/dpteca/media-serve
    <Directory /home/dpteca/media-serve>
        Require all granted
    </Directory>

    # Configurazione WSGI (nome processo distinto dall'altra app)
    WSGIDaemonProcess dpteca_casanausicaa python-home=/home/dpteca/dpteca/venv python-path=/home/dpteca/dpteca
    WSGIProcessGroup dpteca_casanausicaa
    WSGIScriptAlias / /home/dpteca/dpteca/dpteca/wsgi.py

    <Directory /home/dpteca/dpteca/dpteca>
        <Files wsgi.py>
            Require all granted
        </Files>
    </Directory>

    # Permetti accesso a tutto il progetto
    <Directory /home/dpteca/dpteca>
        <Files wsgi.py>
            Require all granted
        </Files>
    </Directory>

    # Log
    ErrorLog ${APACHE_LOG_DIR}/dpteca_casanausicaa_error.log
    CustomLog ${APACHE_LOG_DIR}/dpteca_casanausicaa_access.log combined
</VirtualHost>

# Configurazione SSL (verrà aggiunta automaticamente da certbot)
# <VirtualHost *:443>
#     ServerName dpteca.casanausicaa.it
#     ...
# </VirtualHost>
